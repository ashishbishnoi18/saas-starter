# .env.example — copy to .env and fill in before running `mix phx.server`.
# `.env` is gitignored.
#
# Dev defaults: most of these are optional in dev. The app boots without
# Google OAuth, without SES, without R2, without Stripe — it just disables
# those features and falls back to Swoosh.Adapters.Local for email preview
# at http://localhost:4000/dev/mailbox.

# ==== Core ====
# Canonical hostname (prod). Dev ignores this.
PHX_HOST=localhost
# Secret for cookie signing. Generate with `mix phx.gen.secret`.
SECRET_KEY_BASE=
# Set to "true" on the VPS to enable the HTTP listener from a release.
# Dev and tests ignore this.
PHX_SERVER=true

# ==== Database ====
# Prod: ecto://USER:PASS@HOST/DATABASE
DATABASE_URL=

# ==== Google OAuth ====
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://<PHX_HOST>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==== Email (Amazon SES via SMTP) ====
# See RECIPES/60-setup-ses.md.
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=no-reply@example.com

# ==== Admin (Tailscale-gated) ====
# Comma-separated emails allowed to reach /admin/*
ADMIN_EMAILS=you@example.com

# ==== Cloudflare R2 (object storage) ====
# Activate when using SaasStarter.Storage.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public CDN origin in front of the bucket (empty = fall back to presigned URLs)
PUBLIC_CDN_BASE_URL=https://cdn.example.com

# ==== Backblaze B2 backups ====
# See RECIPES/50-backup-b2.md.
RESTIC_REPOSITORY=b2:mybucket:/saas-prod
RESTIC_PASSWORD=
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=

# ==== Stripe (activate when billing is wired) ====
# See RECIPES/31-add-stripe-billing.md.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=
